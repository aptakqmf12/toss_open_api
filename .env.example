# 토스증권 Open API 자격증명 (개발자 포털에서 앱 등록 후 발급)
# https://developers.tossinvest.com/docs
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 이미 발급받은 access_token 을 직접 쓰고 싶을 때 (client_secret 없이 빠른 확인용)
# 설정하면 client_id/secret 보다 우선 사용됨. 만료되면 직접 갱신해야 함.
TOSS_ACCESS_TOKEN=

# API 베이스 URL (기본값 사용 권장)
TOSS_API_BASE_URL=https://openapi.tossinvest.com

# 특정 계좌만 보고 싶을 때 accountSeq 고정 (비워두면 첫 번째 계좌 사용)
TOSS_ACCOUNT_SEQ=

# 1회 매수 주문 한도 금액 (계좌 통화 기준). 미설정 시 보수적 기본값(100000) 적용.
# 오입력/버그로 인한 대금 주문을 서버에서 차단한다.
MAX_ORDER_AMOUNT=1000000
